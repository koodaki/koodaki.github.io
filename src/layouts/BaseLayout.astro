---
import { ClientRouter, fade } from 'astro:transitions';
import '../styles/global.css';
import '@fontsource-variable/vazirmatn';
import '@fontsource-variable/markazi-text';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'خاطرات فردا | لحظه‌های کوچک، برای همیشه',
  description = 'بایگانی زنده‌ی خاطرات و رشد فرزندم',
} = Astro.props;

const base = import.meta.env.BASE_URL;
const path = Astro.url.pathname;

const navLinks = [
  { label: 'خانه', href: base },
  { label: 'آرشیو', href: `${base}archive/` },
  { label: 'برچسب‌ها', href: `${base}tags/` },
];

const isActive = (href: string) =>
  href === base ? path === base : path.startsWith(href);
---

<!doctype html>
<html lang="fa" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    {/* ناوبری بدون رلودِ کامل (حسِ SPA) با ترنزیشن نرم */}
    <ClientRouter />
    {/* تنظیم تم قبل از رنگ‌آمیزی صفحه تا پرشِ رنگ (FOUC) رخ ندهد */}
    <script is:inline>
      (() => {
        try {
          const saved = localStorage.getItem('theme');
          const dark =
            saved === 'dark' ||
            (!saved && window.matchMedia('(prefers-color-scheme: dark)').matches);
          document.documentElement.classList.toggle('dark', dark);
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="min-h-screen bg-bg text-ink antialiased">
    <header transition:persist transition:animate="none" class="sticky top-0 z-50 border-b border-line bg-bg/80 backdrop-blur-md">
      <div class="mx-auto flex h-16 max-w-6xl items-center justify-between gap-4 px-5 sm:h-20 md:px-10">
        <a
          href={base}
          class="font-display text-3xl font-semibold text-primary no-underline sm:text-4xl"
        >
          خاطرات فردا
        </a>

        <nav class="hidden items-center gap-7 sm:flex">
          {
            navLinks.map((link) => (
              <a
                href={link.href}
                data-nav-link
                class:list={[
                  'text-sm no-underline transition-colors',
                  isActive(link.href)
                    ? 'font-bold text-primary'
                    : 'text-muted hover:text-primary',
                ]}
              >
                {link.label}
              </a>
            ))
          }
        </nav>

        <div class="flex items-center gap-3">


          <button
            id="theme-toggle"
            type="button"
            aria-label="تغییر حالت روشن/تاریک"
            class="grid size-10 place-items-center rounded-full border border-line bg-surface text-ink transition hover:border-primary hover:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary"
          >
            <svg class="size-5 dark:hidden" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
            <svg class="hidden size-5 dark:block" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="4"></circle>
              <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path>
            </svg>
          </button>
        </div>
      </div>

      {/* ناوبری موبایل */}
      <nav class="flex items-center justify-center gap-6 border-t border-line/70 py-2.5 sm:hidden">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              data-nav-link
              class:list={[
                'text-sm no-underline transition-colors',
                isActive(link.href) ? 'font-bold text-primary' : 'text-muted',
              ]}
            >
              {link.label}
            </a>
          ))
        }
      </nav>
    </header>

    <main transition:animate="fade">
      <slot />
    </main>

    <script>
      // مدیریت تم سازگار با ناوبری SPA (View Transitions).
      function applyTheme() {
        try {
          const saved = localStorage.getItem('theme');
          const dark =
            saved === 'dark' ||
            (!saved && window.matchMedia('(prefers-color-scheme: dark)').matches);
          document.documentElement.classList.toggle('dark', dark);
        } catch (e) {}
      }

      // پس از هر جابه‌جایی صفحه، تم را دوباره اعمال کن تا پرش رنگ رخ ندهد.
      document.addEventListener('astro:after-swap', applyTheme);

      // دکمه‌ی سوییچ تم بعد از هر ناوبری باید دوباره به المان جدید وصل شود.
      function setupThemeToggle() {
        const btn = document.getElementById('theme-toggle');
        if (!btn || btn.dataset.bound) return;
        btn.dataset.bound = '1';
        btn.addEventListener('click', () => {
          const isDark = document.documentElement.classList.toggle('dark');
          try {
            localStorage.setItem('theme', isDark ? 'dark' : 'light');
          } catch (e) {}
        });
      }
      document.addEventListener('astro:page-load', setupThemeToggle);

      function updateActiveNav() {
        const path = window.location.pathname;
        const base = import.meta.env.BASE_URL || '/';
        document.querySelectorAll('[data-nav-link]').forEach((a) => {
          const href = a.getAttribute('href');
          if (!href) return;
          const active = href === base ? path === base : path.startsWith(href);
          a.classList.toggle('font-bold', active);
          a.classList.toggle('text-primary', active);
          a.classList.toggle('text-muted', !active);
          if (active) {
            a.classList.remove('hover:text-primary');
          } else {
            a.classList.add('hover:text-primary');
          }
        });
      }
      document.addEventListener('astro:page-load', updateActiveNav);
    </script>
  </body>
</html>
