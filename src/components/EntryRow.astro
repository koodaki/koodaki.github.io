---
import { withBase } from '../lib/url';
import { formatFaDate } from '../lib/content';

interface Props {
  slug: string;
  title: string;
  date: Date;
  cover?: string;
  tags: string[];
  excerpt?: string;
  hasAudio?: boolean;
}

const { slug, title, date, cover, tags, excerpt, hasAudio } = Astro.props;
const base = import.meta.env.BASE_URL;
const href = `${base}memories/${slug}/`;
const jYear = date.toLocaleDateString('fa-IR', { year: 'numeric' });
---

<a
  href={href}
  data-tags={tags.join(',')}
  data-date={formatFaDate(date)}
  data-jyear={jYear}
  class="group block rounded-xl border border-line/60 bg-surface p-6 no-underline transition-all hover:border-primary/30 hover:shadow-[0_6px_24px_rgba(142,151,117,0.12)] sm:p-8"
>
  <div class="flex flex-col gap-6 md:flex-row md:items-start md:justify-between">
    <div class="flex-grow space-y-3">
      <div class="flex items-center gap-3 text-muted">
        <time class="text-xs" datetime={date.toISOString()}>{formatFaDate(date)}</time>
        {
          hasAudio && (
            <span class="inline-flex items-center gap-1 text-xs text-primary" title="دارای فایل صوتی">
              <svg class="size-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 10v4M7 6v12M11 3v18M15 7v10M19 10v4"></path>
              </svg>
            </span>
          )
        }
      </div>

      <h3 class="font-display text-2xl font-medium text-ink transition-colors group-hover:text-primary">
        {title}
      </h3>

      {excerpt && <p class="line-clamp-2 max-w-xl text-sm leading-relaxed text-muted">{excerpt}</p>}

      {
        tags.length > 0 && (
          <div class="flex flex-wrap gap-2 pt-1">
            {tags.map((t) => (
              <span class="rounded bg-surface-2 px-2 py-0.5 text-[11px] text-muted">{t}</span>
            ))}
          </div>
        )
      }
    </div>

    {
      cover && (
        <div class="h-32 w-full flex-shrink-0 overflow-hidden rounded-lg bg-surface-2 md:w-36">
          <img
            src={withBase(cover)}
            alt={title}
            loading="lazy"
            class="size-full object-cover transition-transform duration-500 group-hover:scale-105"
          />
        </div>
      )
    }
  </div>
</a>
